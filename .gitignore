# --- Dependencies / package managers (optional for vanilla sites) ---
node_modules/
pnpm-lock.yaml
package-lock.json
yarn.lock

# --- Build / output (if you later add a bundler) ---
dist/
build/
out/
.cache/
.parcel-cache/
.vite/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Environment files (keep secrets out of git) ---
.env
.env.*
!.env.example

# --- Editor / IDE ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
.idea/
*.swp
*.swo
*~

# --- OS / filesystem ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Misc ---
*.tgz
*.zip
